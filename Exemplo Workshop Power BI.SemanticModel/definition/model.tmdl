model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["dClientes","dLocalizacao","dProdutos","fVendas"]

annotation PBI_ProTooling = ["TMDLView_Desktop","MCP-PBIModeling","DevMode"]

ref table dClientes
ref table dLocalizacao
ref table dProdutos
ref table fVendas
ref table dCalendario
ref table _Medidas

ref cultureInfo pt-BR

